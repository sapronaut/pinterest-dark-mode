{
  "manifest_version": 3,
  "name": "Pinterest Dark Mode",
  "version": "1.0.0",
  "description": "Applies a clean dark theme to Pinterest.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.pinterest.com/*"],
      "css": ["dark.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Pinterest Dark Mode"
  }
}
